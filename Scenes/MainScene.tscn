script = ExtResource("8_f140w")
intro_dialogue_them = Array[String](["Look, you're right.", "Times have been getting real tough.", "Prices climb, but the quality falls.", "Taxes rise, but services get worse.", "The elites sail out among the stars...", "... and keep us thrashing in the dirt.", "So yeah, I get the impulse to lash out.", "But still, stealing a skimmer?               A bold move.", "A stupid move.", "Y'know one of them capital ships is gonna come blast you into dust!", "So then why? You think you're gonna tear it all down by yourself?", "You think you can fight the entire system in a jacked-up cargo skimmer?", "...", "...", "...", "...", "...", "I'm rooting for ya buddy."])
